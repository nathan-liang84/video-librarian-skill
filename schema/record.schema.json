{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VideoLibrarian Media Record",
  "description": "单个视频/照片素材的标准化记录。各管线阶段逐步填充字段。这是跨阶段、跨模型协作的共享契约——改字段须同步 PRD §5 与 config/vocab.yaml。",
  "type": "object",
  "required": ["id", "media_type", "original_name", "path", "status", "schema_version"],
  "properties": {
    "id": { "type": "string", "description": "文件内容指纹(SHA1 前16位),去重主键" },
    "media_type": { "type": "string", "enum": ["video", "photo"] },
    "original_name": { "type": "string" },
    "new_name": { "type": ["string", "null"], "description": "规范化新文件名(简短)" },
    "path": { "type": "string", "description": "当前路径/云盘相对路径" },
    "thumbnail": { "type": ["string", "null"], "description": "缩略图路径;视频另含雪碧图" },
    "sprite": { "type": ["string", "null"] },
    "live_motion_path": { "type": ["string", "null"], "description": "Live Photo 配对的动态 .mov 路径;该 .mov 自身记 status=live_motion_skip" },

    "is_junk": { "type": ["boolean", "null"], "description": "是否判为垃圾(截图/翻拍/表情包等)。01b 置 status=junk;经 05_store 入库后可能为 status=stored 且 is_junk=true —— is_junk 是 06 排除召回的持久标记" },
    "junk_reason": { "type": ["string", "null"], "description": "垃圾原因(screenshot/document/meme…)" },
    "group_id": { "type": ["string", "null"], "description": "近重复/连拍组 ID(同组共享);仅代表帧进精理解" },
    "is_representative": { "type": ["boolean", "null"], "description": "是否本组代表(只有代表进 02/03 精理解)" },
    "group_size": { "type": ["integer", "null"], "description": "本组成员数" },

    "duration_sec": { "type": ["number", "null"] },
    "resolution": { "type": ["string", "null"] },
    "fps": { "type": ["number", "null"] },
    "codec": { "type": ["string", "null"] },
    "filesize_mb": { "type": ["number", "null"] },
    "shot_at": { "type": ["string", "null"], "format": "date-time" },
    "gps": { "type": ["string", "null"] },
    "device": { "type": ["string", "null"] },

    "summary": { "type": ["string", "null"], "description": "一句话总结" },
    "description": { "type": ["string", "null"] },
    "scene": { "type": "array", "items": { "type": "string" }, "description": "受控:vocab.scene" },
    "subjects": { "type": "array", "items": { "type": "string" }, "description": "人物:来自 config 名册(如 <主角>/<主角>和<同伴>/<主角>和<宠物>)或 多人/空镜" },
    "main_subject": { "type": ["string", "null"], "description": "画面主体(命名锚点):简短名词。人物→名册人名,否则→物品/建筑/风景词(如 柠檬茶/教堂/海岸线)。由模型判断主次" },
    "subject_kind": { "type": ["string", "null"], "enum": ["人物", "物品", "建筑", "风景", "动物", "食物", "其他", null], "description": "受控:vocab.subject_kind,main_subject 属于哪类" },
    "actions": { "type": "array", "items": { "type": "string" } },

    "shot_type": { "type": ["string", "null"], "description": "受控:vocab.shot_type" },
    "camera_move": { "type": "array", "items": { "type": "string" }, "description": "受控:vocab.camera_move(视频)" },
    "mood": { "type": "array", "items": { "type": "string" }, "description": "受控:vocab.mood" },
    "lighting": { "type": ["string", "null"], "description": "受控:vocab.lighting" },
    "quality_score": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
    "subject_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "对 subjects(尤其主角)身份判断的把握;没露脸/靠外观推断时偏低" },
    "subject_basis": { "type": ["string", "null"], "enum": ["face", "appearance", "inferred", "none", null], "description": "身份判断依据:face=看到脸/appearance=发型身形穿搭等外观/inferred=主角先验推断/none=无人或无法判断" },
    "has_speech": { "type": ["boolean", "null"] },
    "transcript": { "type": ["string", "null"] },
    "usable_clips": {
      "type": "array",
      "description": "可用片段时间码(视频)",
      "items": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": { "type": "number", "description": "起始秒" },
          "end": { "type": "number", "description": "结束秒" },
          "reason": { "type": "string" }
        }
      }
    },
    "suggested_use": { "type": "array", "items": { "type": "string" }, "description": "受控:vocab.suggested_use" },
    "tags": { "type": "array", "items": { "type": "string" }, "description": "受控词表外的自由补充标签" },
    "keyword": { "type": ["string", "null"], "description": "命名用关键词(2-4字),03 产出" },

    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["pending", "extracted", "understood", "named", "stored", "needs_review", "failed", "live_motion_skip", "junk", "grouped"] },
    "schema_version": { "type": "string" },
    "processed_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
